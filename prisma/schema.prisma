generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model usuario {
  idUsuario       Int     @id @default(autoincrement())
  usuNombre       String  @db.VarChar(100)
  usuApellido     String  @db.VarChar(100)
  usuDocumento    String  @unique @db.VarChar(15)
  usuTelefono     String  @db.VarChar(10)          
  usuCorreo       String  @unique @db.VarChar(80)
  usuPassword     String  @db.VarChar(60)           
  usuDireccion    String  @db.VarChar(200)
  usuEstado       String  @db.VarChar(20)
  fkIdRol         Int?

  rol                 rol?                  @relation(fields: [fkIdRol], references: [idRol])
  carrito             carrito[]
  cita                cita[]
  log_acceso          log_acceso[]
  notificacion        notificacion[]
  webpush_suscripcion webpush_suscripcion[]
}

model rol {
  idRol          Int     @id @default(autoincrement())
  rolNombre      String  @unique @db.VarChar(50)
  rolDescripcion String? @db.VarChar(200)

  usuario        usuario[]
}

model carrito {
  idCarrito        Int      @id @default(autoincrement())
  carFechaCreacion DateTime @default(now())
  carEstado        String   @db.VarChar(20)
  fkIdUsuario      Int

  usuario          usuario            @relation(fields: [fkIdUsuario], references: [idUsuario])
  carrito_producto carrito_producto[]
  factura          factura[]
}

model carrito_producto {
  idCarritoProducto Int @id @default(autoincrement())
  fkIdCarrito       Int
  fkIdProducto      Int
  cantidad          Int

  carrito  carrito  @relation(fields: [fkIdCarrito], references: [idCarrito])
  producto producto @relation(fields: [fkIdProducto], references: [idProducto])

  @@unique([fkIdCarrito, fkIdProducto])
}

model producto {
  idProducto     Int     @id @default(autoincrement())
  proNombre      String  @db.VarChar(150)
  proDescripcion String? @db.Text
  proCategoria   String  @db.VarChar(50)
  proPrecio      Decimal @db.Decimal(10, 2)
  proStock       Int
  proEstado      String  @db.VarChar(20)
  proImagen      String? @db.VarChar(255)

  carrito_producto carrito_producto[]
}

model factura {
  idFactura      Int      @id @default(autoincrement())
  facNumero      String   @unique @db.VarChar(50)
  facFecha       DateTime @default(now())
  facConcepto    String   @db.VarChar(200)
  facCondiciones String?  @db.VarChar(300)
  facSubtotal    Decimal  @db.Decimal(10, 2)
  facIva         Decimal  @db.Decimal(10, 2)
  facTotal       Decimal  @db.Decimal(10, 2)
  fkIdCarrito    Int

  carrito  carrito  @relation(fields: [fkIdCarrito], references: [idCarrito])
  encuesta encuesta[]
}

model cita {
  idCita           Int      @id @default(autoincrement())
  citFecha         DateTime
  citMotivo        String   @db.VarChar(200)
  citEstado        String   @db.VarChar(20)
  citObservaciones String?  @db.VarChar(300)
  fkIdUsuario      Int

  usuario          usuario  @relation(fields: [fkIdUsuario], references: [idUsuario])
  historia_clinica historia_clinica[]
  encuesta         encuesta[]
}

model historia_clinica {
  idHistoriaClinica Int      @id @default(autoincrement())
  hisFecha          DateTime @default(now())
  hisDiagnostico    String   @db.Text
  hisFormulaOptica  String   @db.Text
  hisObservaciones  String?  @db.Text
  fkIdCita          Int

  cita cita @relation(fields: [fkIdCita], references: [idCita])
}

model encuesta {
  idEncuesta  Int      @id @default(autoincrement())
  enFecha     DateTime @default(now())
  enTipo      String   @db.VarChar(50)
  fkIdFactura Int?
  fkIdCita    Int?

  factura factura? @relation(fields: [fkIdFactura], references: [idFactura])
  cita    cita?    @relation(fields: [fkIdCita], references: [idCita])

  respuesta_encuesta respuesta_encuesta[]
}

model pregunta {
  idPregunta   Int     @id @default(autoincrement())
  preTexto     String  @db.VarChar(300)
  preTipo      String  @db.VarChar(50)
  preCategoria String  @db.VarChar(50)
  preActiva    Boolean @default(true)

  respuesta_encuesta respuesta_encuesta[]
}

model respuesta_encuesta {
  idRespuesta  Int    @id @default(autoincrement())
  resValor     String @db.VarChar(300)
  fkIdPregunta Int
  fkIdEncuesta Int

  pregunta pregunta @relation(fields: [fkIdPregunta], references: [idPregunta])
  encuesta encuesta @relation(fields: [fkIdEncuesta], references: [idEncuesta])
}

model notificacion {
  idNotificacion     Int      @id @default(autoincrement())
  notTitulo          String   @db.VarChar(150)
  notMensaje         String   @db.Text
  notCanal           String   @db.VarChar(30)
  notEstado          String   @db.VarChar(20)
  notFechaProgramada DateTime
  fkIdUsuario        Int

  usuario usuario @relation(fields: [fkIdUsuario], references: [idUsuario])
}

model log_acceso {
  idLogAcceso Int      @id @default(autoincrement())
  logAccion   String   @db.VarChar(100)
  logFecha    DateTime @default(now())
  logIP       String   @db.VarChar(45)
  logRecurso  String   @db.VarChar(150)
  fkIdUsuario Int

  usuario usuario @relation(fields: [fkIdUsuario], references: [idUsuario])
}

model webpush_suscripcion {
  idWebpushSuscripcion Int      @id @default(autoincrement())
  webEndpoint          String   @unique @db.VarChar(500)
  webP256dh            String   @db.VarChar(255)
  webAuth              String   @db.VarChar(255)
  webFechaRegistro     DateTime @default(now())
  fkIdUsuario          Int

  usuario usuario @relation(fields: [fkIdUsuario], references: [idUsuario])
}